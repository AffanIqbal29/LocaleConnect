rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Provide full read and write access to all documents in the database.
    // Note: This is intended for development and prototyping. 
    // For a production app, you should restrict access based on authentication and ownership.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}